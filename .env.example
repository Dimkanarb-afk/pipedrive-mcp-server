# Pipedrive API credentials
# Get your API token from: Pipedrive → Settings → Personal Preferences → API
PIPEDRIVE_API_TOKEN=your_api_token_here

# Your Pipedrive company subdomain
# e.g. if your Pipedrive URL is https://mycompany.pipedrive.com, use: mycompany
PIPEDRIVE_COMPANY_DOMAIN=your_company_subdomain
